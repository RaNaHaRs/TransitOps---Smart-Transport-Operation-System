# Copy this file to .env and replace the values for your local environment.
DB_USERNAME=root
DB_PASSWORD=replace-with-your-mysql-password
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
# Base64-encoded value representing at least 32 random bytes.
JWT_SECRET=replace-with-a-base64-encoded-32-byte-secret
JWT_EXPIRATION_MS=86400000
